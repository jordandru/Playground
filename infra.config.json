{
  "requirements": {
    "nodeMajorGte": 24,
    "files": ["README.md", ".gitignore", ".editorconfig", ".gitattributes", "infra.config.json"],
    "directories": ["src", "test"],
    "ciWorkflow": ".github/workflows/ci.yml",
    "packageJson": {
      "requiredScripts": ["infra:check", "infra:doctor", "infra:fix", "infra:init", "infra:status", "infra:snapshot", "test", "check"]
    },
    "git": {
      "mustExist": true,
      "mustHaveCommit": false,
      "mustHaveRemote": false
    }
  }
}
